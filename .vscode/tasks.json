{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Ingest All (venv)",
			"type": "shell",
			"command": ".\\.venv\\Scripts\\python.exe",
			"args": [
				"-m",
				"src.main",
				"ingest-all"
			],
			"group": "build"
		},
		{
			"label": "Dashboard (venv)",
			"type": "shell",
			"command": ".\\.venv\\Scripts\\python.exe",
			"args": [
				"-m",
				"streamlit",
				"run",
				"streamlit_app.py",
				"--server.headless",
				"true",
				"--server.port",
				"8501"
			],
			"isBackground": true,
			"group": "build"
		},
		{
			"label": "Refresh Dashboard (venv)",
			"type": "shell",
			"command": ".\\.venv\\Scripts\\python.exe",
			"args": [
				"-m",
				"src.main",
				"refresh-dashboard",
				"--server-address",
				"127.0.0.1",
				"--server-port",
				"8501"
			],
			"isBackground": true,
			"group": "build"
		}
	]
}