/var/log/f9-congress-trading/ingest.log {
    # Daily ingest log: one run per night, a few hundred lines.
    # Keep 30 days, gzip older rotations, recreate the live file with
    # predictable perms so the cron's `>>` has a destination.
    daily
    rotate 30
    compress
    delaycompress
    missingok
    notifempty
    create 0640 root root
    dateext
    dateformat -%Y%m%d
}
