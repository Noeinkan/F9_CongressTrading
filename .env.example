# Copy this file to `.env` in the repo root and fill in values.
# `.env` is gitignored — never commit secrets.

POLYGON_API_KEY=
OPENFIGI_API_KEY=

# Optional: speed up ticker API calls (lower = faster; too low may trigger HTTP 429).
# POLYGON_MIN_INTERVAL_SECONDS=0.2
# OPENFIGI_MIN_INTERVAL_SECONDS=0.25

# Re-resolve: skip Polygon GET /v3/reference/tickers/{ticker} (issuer detail); faster, sector/SIC from heuristics only.
# CONGRESS_SKIP_POLYGON_TICKER_DETAILS=1

# Re-resolve: disable batched OpenFIGI (100 names per POST); only for debugging.
# CONGRESS_DISABLE_RE_RESOLVE_OPENFIGI_BATCH=1

# Re-resolve: prefetch all distinct assets before updating transactions (slower; default off).
# CONGRESS_RE_RESOLVE_TICKERS_BULK=0

# Note: name resolution uses OpenFIGI /v3/search (one request per asset). OPENFIGI_BATCH_SIZE is unused.

# Optional: name-match thresholds (defaults are more permissive than legacy 88/85).
# POLYGON_FUZZY_MIN_SCORE=82
# OPENFIGI_FUZZY_MIN_SCORE=78

# Optional: restrict OpenFIGI name mapping to Common Stock only (narrower; can miss ADRs).
# OPENFIGI_NAME_STRICT_COMMON_STOCK=0
