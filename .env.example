# Copy this file to `.env` in the repo root and fill in values.
# `.env` is gitignored — never commit secrets.

POLYGON_API_KEY=
OPENFIGI_API_KEY=

# Optional: speed up ticker API calls (lower = faster; too low may trigger HTTP 429).
# POLYGON_MIN_INTERVAL_SECONDS=0.2
# OPENFIGI_MIN_INTERVAL_SECONDS=0.35
