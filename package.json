{
  "name": "f9-congress-trading",
  "private": true,
  "version": "0.1.0",
  "description": "Congress trading tracker - local dev orchestrator (API + Dashboard)",
  "scripts": {
    "start": "concurrently -k -n API,WEB -c blue,green \"npm:dev:api\" \"npm:dev:web\"",
    "dev": "concurrently -k -n API,WEB -c blue,green \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "node scripts/dev-api.js",
    "dev:web": "npm --prefix frontend run dev",
    "start:web-only": "npm:dev:web",
    "start:api-only": "npm:dev:api",
    "start:detach": "powershell -NoProfile -Command \"Start-Process powershell -ArgumentList '-NoProfile','-Command',\\\"cd '$((Get-Location).Path)'; npm start\\\" -Verb RunAs\"",
    "install:all": "npm install && npm --prefix frontend install",
    "clean": "powershell -NoProfile -File scripts/clean-ports.ps1",
    "predev:api": "node scripts/check-venv.js"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
